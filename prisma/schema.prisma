// NAUKA INVENTRA V1.1 - Sistem Operasional Bisnis untuk UMKM
// Foundation for Nauka ERP Core

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ===================== AUTH & USER =====================

model User {
  id           String        @id @default(cuid())
  username     String        @unique
  name         String
  email        String?
  password     String
  role         String        @default("staff") // owner, admin, staff, warehouse
  isActive     Boolean       @default(true)
  activityLogs ActivityLog[]
  attachments  Attachment[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

// ===================== MASTER DATA =====================

model Category {
  id          String    @id @default(cuid())
  name        String
  description String?
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Supplier {
  id        String         @id @default(cuid())
  code      String         @unique
  name      String
  pic       String?
  phone     String?
  email     String?
  address   String?
  notes     String?
  products  Product[]
  purchases Purchase[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model Customer {
  id        String    @id @default(cuid())
  code      String    @unique
  name      String
  phone     String?
  email     String?
  address   String?
  notes     String?
  sales     Sale[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// ===================== WAREHOUSE =====================

model Warehouse {
  id       String           @id @default(cuid())
  name     String
  code     String           @unique
  address  String?
  isActive Boolean          @default(true)
  stocks   WarehouseStock[]
  mutations StockMutation[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model WarehouseStock {
  id              String     @id @default(cuid())
  warehouseId     String
  productVariantId String
  stock           Int        @default(0)
  warehouse       Warehouse  @relation(fields: [warehouseId], references: [id])
  variant         ProductVariant @relation(fields: [productVariantId], references: [id])
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@unique([warehouseId, productVariantId])
}

// ===================== PRODUCT & VARIANT =====================

model Product {
  id            String           @id @default(cuid())
  name          String
  sku           String           @unique
  categoryId    String
  supplierId    String?
  description   String?
  image         String?          // URL or path to product image
  buyPrice      Float            @default(0) // base buy price
  sellPrice     Float            @default(0) // base sell price
  minStock      Int              @default(0)
  isActive      Boolean          @default(true)
  category      Category         @relation(fields: [categoryId], references: [id])
  supplier      Supplier?        @relation(fields: [supplierId], references: [id])
  variants      ProductVariant[]
  purchaseItems PurchaseItem[]
  saleItems     SaleItem[]
  stockMutations StockMutation[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
}

model ProductVariant {
  id           String           @id @default(cuid())
  productId    String
  name         String           // e.g. "Black M", "White L"
  sku          String           // e.g. "OVT-BLK-M"
  attributes   String           // JSON: {"color":"Black","size":"M"}
  buyPrice     Float            @default(0) // variant-specific price
  sellPrice    Float            @default(0) // variant-specific price
  stock        Int              @default(0) // total stock across all warehouses
  minStock     Int              @default(0)
  isActive     Boolean          @default(true)
  barcode      String?
  product      Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouseStocks WarehouseStock[]
  purchaseItems PurchaseItem[]
  saleItems    SaleItem[]
  stockMutations StockMutation[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@unique([sku])
}

// ===================== PURCHASE =====================

model Purchase {
  id         String         @id @default(cuid())
  transNo    String         @unique
  supplierId String
  date       DateTime
  total      Float          @default(0)
  status     String         @default("DRAFT") // DRAFT, APPROVED, RECEIVED, CANCELLED
  notes      String?
  supplier   Supplier       @relation(fields: [supplierId], references: [id])
  items      PurchaseItem[]
  attachments Attachment[]
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
}

model PurchaseItem {
  id           String         @id @default(cuid())
  purchaseId   String
  variantId    String?        // nullable for backward compat, prefer variant
  productId    String?        // fallback when no variant
  qty          Int
  buyPrice     Float
  variant      ProductVariant? @relation(fields: [variantId], references: [id])
  product      Product?       @relation(fields: [productId], references: [id])
  purchase     Purchase       @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
}

// ===================== SALE =====================

model Sale {
  id         String       @id @default(cuid())
  transNo    String       @unique
  customerId String?
  date       DateTime
  total      Float        @default(0)
  status     String       @default("DRAFT") // DRAFT, PAID, COMPLETED, CANCELLED
  notes      String?
  customer   Customer?    @relation(fields: [customerId], references: [id])
  items      SaleItem[]
  attachments Attachment[]
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
}

model SaleItem {
  id         String         @id @default(cuid())
  saleId     String
  variantId  String?        // nullable for backward compat, prefer variant
  productId  String?        // fallback when no variant
  qty        Int
  sellPrice  Float
  variant    ProductVariant? @relation(fields: [variantId], references: [id])
  product    Product?       @relation(fields: [productId], references: [id])
  sale       Sale           @relation(fields: [saleId], references: [id], onDelete: Cascade)
}

// ===================== STOCK MUTATION =====================

model StockMutation {
  id          String         @id @default(cuid())
  variantId   String?        // prefer variant
  productId   String?        // fallback
  warehouseId String?
  type        String         // IN, OUT, ADJUSTMENT
  qty         Int
  note        String?
  referenceId String?        // purchase or sale id
  variant     ProductVariant? @relation(fields: [variantId], references: [id])
  product     Product?       @relation(fields: [productId], references: [id])
  warehouse   Warehouse?     @relation(fields: [warehouseId], references: [id])
  createdAt   DateTime       @default(now())
}

// ===================== ACTIVITY LOG =====================

model ActivityLog {
  id           String    @id @default(cuid())
  userId       String
  action       String    // CREATE, UPDATE, DELETE, LOGIN, STATUS_CHANGE
  entity       String    // Product, Purchase, Sale, User, etc.
  entityId     String?   // Polymorphic - no FK, just a string reference
  entityCode   String?   // Human-readable code (e.g., "PO-20260607-0001", "CUS000013")
  details      String    // JSON string with change details
  previousData String?   // JSON string of previous values (for UPDATE/STATUS_CHANGE)
  newData      String?   // JSON string of new values (for UPDATE/STATUS_CHANGE)
  user         User      @relation(fields: [userId], references: [id])
  createdAt    DateTime  @default(now())
}

// ===================== INBOX =====================

model Inbox {
  id         String   @id @default(cuid())
  userId     String?  // null = broadcast to all users
  type       String   // stock_low, purchase_status, sale_status, customer_created, purchase_received, stock_mutation, general
  title      String
  message    String
  entity     String?  // Entity type: Product, Purchase, Sale, Customer, etc.
  entityId   String?  // Entity ID reference
  entityCode String?  // Human-readable code
  isRead     Boolean  @default(false)
  priority   String   @default("info") // urgent, warning, info
  createdAt  DateTime @default(now())
}

// ===================== ATTACHMENT =====================

model Attachment {
  id         String    @id @default(cuid())
  entity     String    // Purchase, Sale, Product, etc.
  entityId   String
  fileName   String
  filePath   String
  fileType   String    // image, pdf, document
  fileSize   Int       @default(0)
  uploadedBy String?
  user       User?     @relation(fields: [uploadedBy], references: [id])
  purchase   Purchase? @relation(fields: [entityId], references: [id])
  sale       Sale?     @relation(fields: [entityId], references: [id])
  createdAt  DateTime  @default(now())
}
